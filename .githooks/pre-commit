#!/usr/bin/env bash
# Installed via `nix develop`'s shellHook (see flake.nix devShells.default),
# which points git's core.hooksPath at this tracked directory.
set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

echo "[pre-commit] checking gofmt..."
unformatted="$(gofmt -l .)"
if [ -n "$unformatted" ]; then
	echo "[pre-commit] not gofmt'd:" >&2
	echo "$unformatted" >&2
	echo "[pre-commit] run: gofmt -w <file>..." >&2
	exit 1
fi

echo "[pre-commit] running go test ./..."
go test ./... -count=1 -short

echo "[pre-commit] building nix flake..."
nix build . -L
