# chunk splits continuous data into fixed windows, emitted as a JSON array.
produce "generate" "slicing" {
  values = ["abcdef"]
}

transform "chunk" "c" {
  size = 2
}

pipeline "slicing" {
  produce   = [produce.generate.slicing]
  transform = [transform.chunk.c]
  consume   = [consume.file.out]
}
