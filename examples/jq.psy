# filter drops messages whose predicate is false/null; jq reshapes what remains.
produce "generate" "jq" {
  values = [
    "{\"v\":1,\"keep\":true}",
    "{\"v\":2,\"keep\":false}",
  ]
}

transform "filter" "jq" {
  expression = ".keep"
}

transform "jq" "v" {
  expression = ".v"
}

pipeline "jq" {
  produce   = [produce.generate.jq]
  transform = [transform.filter.jq, transform.jq.v]
  consume   = [consume.file.out]
}
