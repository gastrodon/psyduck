# sequence emits an integer stream; head passes only the first n.
import {
  shared = "shared.psy"
}

produce "sequence" "flow" {
  stop-after = 10
}

transform "head" "flow" {
  count = 3
}

pipeline "flow" {
  produce   = [produce.sequence.flow]
  transform = [transform.head.flow]
  consume   = [imports.shared.consume.file.out]
}
