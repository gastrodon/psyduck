# count replaces the message with a running tally every n messages.
import {
  shared = "shared.psy"
}

produce "sequence" "dev" {
  stop-after = 3
}

transform "count" "dev" {
  prefix = "n="
}

pipeline "dev" {
  produce   = [produce.sequence.dev]
  transform = [transform.count.dev]
  consume   = [imports.shared.consume.file.out]
}
